<?xml version="1.0" encoding="utf-8"?>
<!--
    res/color/bottom_nav_selector.xml
    ════════════════════════════════════════════════════════════════════════════
    ColorStateList para los iconos y texto del BottomNavigationView.

    state_checked=true  → pestaña activa → color primario (rosa)
    default             → pestaña inactiva → gris

    Material Design recomienda:
      Activo   → colorPrimary con opacidad completa
      Inactivo → color neutro con opacidad reducida
    ════════════════════════════════════════════════════════════════════════════
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="#E91E63" android:state_checked="true"/>
    <item android:color="#9E9E9E"/>
</selector>
