<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#1E1E1E">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Backdrop Banner (Imagen horizontal grande) -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="250dp"
            android:id="@+id/ivBackdrop"
            android:scaleType="centerCrop"
            android:background="#2C2C2C"
            android:contentDescription="Movie Backdrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Gradient overlay sobre el backdrop -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:id="@+id/gradientOverlay"
            android:background="@drawable/gradient_backdrop"
            app:layout_constraintTop_toTopOf="@+id/ivBackdrop"
            app:layout_constraintBottom_toBottomOf="@id/ivBackdrop"
            app:layout_constraintStart_toStartOf="@id/ivBackdrop"
            app:layout_constraintEnd_toEndOf="@id/ivBackdrop"/>

        <!-- Botón regresar -->
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:id="@+id/btnBack"
            android:layout_margin="16dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_back_button"
            android:contentDescription="Back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Container de poster y info básica -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:id="@+id/headerContainer"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginTop="-50dp"
            app:layout_constraintTop_toBottomOf="@id/ivBackdrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Poster (imagen vertical) -->
            <androidx.cardview.widget.CardView
                android:layout_width="120dp"
                android:layout_height="180dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:id="@+id/ivPosterDetail"
                    android:scaleType="centerCrop"
                    android:background="#2C2C2C"
                    android:contentDescription="Movie Poster" />

            </androidx.cardview.widget.CardView>

            <!-- Info básica al lado del poster -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginTop="50dp">

                <!-- Rating -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvRatingDetail"
                    android:text="⭐ 8.5/10"
                    android:textColor="#FFC107"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <!-- votos -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvVotesDetail"
                    android:text="1234 votos"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <!-- Fecha de estreno -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvReleaseDetail"
                    android:text="2024-12-15"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

                <!-- Popularidad -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvPopularityDetail"
                    android:text="🔥 450.5"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Titulo de pelicula -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:id="@+id/tvTitleDetail"
            android:text="Movie Title"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@+id/headerContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Seccion Overview -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:id="@+id/labelOverview"
            android:text="Sinopsis"
            android:textColor="#4CAF50"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/tvTitleDetail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- overview texto -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:id="@+id/tvOverviewDetail"
            android:text="Movie overview..."
            android:textColor="#CCCCCC"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@+id/labelOverview"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Espacio al final -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvOverviewDetail"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>