<?xml version="1.0" encoding="utf-8"?>
<!--
    PATRÓN: Single Activity Container
    ────────────────────────────────────────────────────────────────────────────
    Esta Activity es solo un CONTENEDOR vacío. Toda la UI real vive en los
    Fragments. El único elemento funcional aquí es el NavHostFragment.

    NavHostFragment:
      • Es el "motor" del Navigation Component
      • Gestiona el back stack de fragments
      • Intercambia los fragments según las actions del nav_graph
      • app:navGraph   → vincula el grafo de navegación
      • app:defaultNavHost → intercepta el botón Back del sistema y lo maneja
                            automáticamente según el back stack del grafo

    MATERIAL DESIGN 3:
      • Se usa CoordinatorLayout como raíz para permitir comportamientos
        coordinados (ej: Snackbars, CollapsingToolbar en pantallas hijas)
      • Cada Fragment puede tener su propia Toolbar sin conflictos

    CLEAN ARCHITECTURE:
      La Activity no conoce ninguna pantalla concreta. Solo conoce el
      NavHostFragment. Esto cumple con el principio de inversión de
      dependencias: la Activity depende de la abstracción (NavHost),
      no de los Fragments concretos.
    ════════════════════════════════════════════════════════════════════════════
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!--
        FragmentContainerView es el reemplazo moderno de FrameLayout para
        Fragments. Ventajas sobre FrameLayout:
          • Maneja correctamente las animaciones de entrada/salida
          • Garantiza que los Fragments solo se dibujen dentro de sus límites
          • Recomendado por Google desde Navigation 2.3+

        android:name="...NavHostFragment"
          → Indica que este contenedor es gestionado por el Navigation Component

        app:navGraph="@navigation/nav_graph"
          → Vincula el grafo que define todas las pantallas

        app:defaultNavHost="true"
          → Solo UNO por layout puede ser true.
            Permite que este NavHost capture el botón Atrás del sistema.
            Sin esto, el Back no navegaría hacia atrás en el grafo.
    -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:navGraph="@navigation/nav_graph"
        app:defaultNavHost="true"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>