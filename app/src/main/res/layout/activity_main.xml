<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E1E"
    android:padding="16dp"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎬 TheMovieDB API"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Implementación con Retrofit"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#333333"
            android:layout_marginBottom="16dp" />

        <!-- Status -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estado:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Esperando..."
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Results -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resultados:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Los resultados aparecerán aquí..."
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <!-- Instruction -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 Tip: Abre Logcat para ver logs detallados"
            android:textSize="12sp"
            android:textColor="#FFC107"
            android:gravity="center"
            android:padding="12dp"
            android:background="#3E2723" />

        <!-- Logcat Instructions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Filtros de Logcat:\n• tag:MainActivity\n• tag:MovieRepository\n• tag:OkHttp"
            android:textSize="11sp"
            android:textColor="#888888"
            android:gravity="center"
            android:paddingTop="8dp"
            android:fontFamily="monospace" />

    </LinearLayout>
</ScrollView>