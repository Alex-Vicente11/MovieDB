<?xml version="1.0" encoding="utf-8"?>
<!--
    ════════════════════════════════════════════════════════════════════════════
    fragment_movie_details.xml — Rediseño completo Material Design 3
    ════════════════════════════════════════════════════════════════════════════

    MEJORAS UX/UI aplicadas:
      • Hero section de 320dp con backdrop en parallax + poster flotante
        elevado sobre el backdrop con sombra (efecto cine)
      • Gradiente multicapa en el hero: el backdrop se funde hacia abajo
        con el fondo de la tarjeta de contenido (no corte abrupto)
      • Chips de géneros horizontales (HorizontalScrollView) → escaneo visual
        rápido, patrón recomendado por Material Design para etiquetas
      • Cards de métricas (rating, votos, año, runtime, popularidad) en grid
        2x2 con iconos → lectura rápida, jerarquía visual clara
      • Cards de datos financieros lado a lado con color semántico
        (verde = ingresos, blanco = presupuesto)
      • Sección sinopsis con label coloreado y línea separadora
      • FAB (Floating Action Button) extendido fijo en la parte inferior
        → acción principal siempre accesible sin hacer scroll
      • Colores explícitos hardcodeados para máxima compatibilidad con
        tema oscuro sin depender de atributos que puedan fallar
    ════════════════════════════════════════════════════════════════════════════
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- ══════════════════════════════════════════════════════════════════════
         HERO — AppBar con CollapsingToolbar y efecto parallax
         320dp de alto: suficiente para ver el backdrop con impacto visual
    ══════════════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="340dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="#1A1A2E"
            app:expandedTitleTextColor="@android:color/transparent"
            app:collapsedTitleTextAppearance="@style/TextAppearance.Material3.TitleMedium"
            app:collapsedTitleTextColor="#FFFFFF"
            app:expandedTitleMarginStart="16dp"
            app:expandedTitleMarginBottom="16dp">

            <!-- Backdrop: imagen de la película en parallax -->
            <ImageView
                android:id="@+id/ivBackdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Backdrop de la película"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.6"
                tools:src="@drawable/ic_movie_placeholder"/>

            <!--
                Gradiente multicapa:
                Capa 1 (top): oscurecimiento suave para legibilidad del toolbar
                Capa 2 (bottom): fundido hacia el color de fondo de la pantalla
                Esto elimina el corte brusco entre hero y contenido.
                Se necesita el drawable gradient_hero_overlay en res/drawable/
            -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_hero_overlay"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.6"/>

            <!-- Toolbar transparente — el botón ← lo provee NavController -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@android:color/transparent"
                app:navigationIconTint="#FFFFFF"
                app:layout_collapseMode="pin"/>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════════════════════════════════════
         CONTENIDO DESPLAZABLE
    ══════════════════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- ── CARD PRINCIPAL: poster flotante + info básica ── -->
            <!--
                El poster "flota" sobre el hero con marginTop negativo:
                sale de la zona del backdrop y se superpone al contenido.
                Patrón visual clásico de apps de cine (Letterboxd, IMDb).
            -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-80dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Poster con sombra elevada -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPoster"
                    android:layout_width="120dp"
                    android:layout_height="180dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="#2C2C3E"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivPosterDetail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="Poster de la película"
                        tools:src="@drawable/ic_movie_placeholder"/>

                </androidx.cardview.widget.CardView>

                <!-- Info primaria al lado del poster -->
                <LinearLayout
                    android:id="@+id/primaryInfoContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="90dp"
                    android:orientation="vertical"
                    app:layout_constraintStart_toEndOf="@id/cardPoster"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <!-- Rating destacado -->
                    <TextView
                        android:id="@+id/tvRatingDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFC107"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="⭐ 8.7/10"/>

                    <!-- Votos -->
                    <TextView
                        android:id="@+id/tvVotesDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        tools:text="25,489 votos"/>

                    <!-- Año -->
                    <TextView
                        android:id="@+id/tvReleaseDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"
                        tools:text="1999"/>

                    <!-- Runtime -->
                    <TextView
                        android:id="@+id/tvRuntimeDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"
                        tools:text="2h 16min"/>

                    <!-- Popularidad -->
                    <TextView
                        android:id="@+id/tvPopularityDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"
                        tools:text="🔥 850.2"/>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ── TÍTULO ── -->
            <TextView
                android:id="@+id/tvTitleDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="16dp"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp"
                tools:text="The Matrix"/>

            <!-- ── TAGLINE ── -->
            <TextView
                android:id="@+id/tvTaglineDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:paddingHorizontal="16dp"
                android:textColor="#E91E63"
                android:textSize="14sp"
                android:textStyle="italic"
                android:visibility="gone"
                tools:text="\Welcome to the Real World."
                tools:visibility="visible"/>

            <!-- ── CHIPS DE GÉNEROS (scroll horizontal) ── -->
            <!--
                HorizontalScrollView con chips → el usuario escanea géneros
                de izquierda a derecha sin ocupar múltiples líneas.
                Los chips son views individuales creados programáticamente
                en el Fragment y añadidos a chipGroupGenres.
            -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupGenres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="16dp"
                app:singleLine="false"
                app:chipSpacingHorizontal="8dp"/>

            <!-- ── DIVIDER ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="#2C2C3E"/>

            <!-- ── SECCIÓN: DATOS FINANCIEROS ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="16dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Card Presupuesto -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#1E1E2E">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💰 Presupuesto"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvBudgetDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="$63.0M"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card Ingresos -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#1E1E2E">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊 Ingresos"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvRevenueDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#4CAF50"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="$467.2M"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── SECCIÓN: SINOPSIS ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="16dp"
                android:text="Sinopsis"
                android:textColor="#E91E63"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:background="#E91E63"/>

            <TextView
                android:id="@+id/tvOverviewDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="16dp"
                android:textColor="#CCCCCC"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                tools:text="A computer hacker learns from mysterious rebels about the true nature of his reality and his role in the war against its controllers."/>

            <!-- Espacio al fondo para que el FAB no tape el texto -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════════════════════════════════════
         PROGRESS BAR — centrada sobre todo
    ══════════════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        app:indicatorColor="#E91E63"
        app:indicatorSize="52dp"
        app:trackColor="#2C2C3E"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         FAB EXTENDIDO — acción principal fija en el fondo
         Siempre visible sin importar el scroll. Patrón Material Design
         para la acción primaria de una pantalla de detalle.
    ══════════════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnWatchVideos"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:text="🎬  Ver Videos y Trailers"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="#E91E63"
        app:elevation="8dp"
        app:rippleColor="#C2185B"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>