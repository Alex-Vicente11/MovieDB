<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_movie_details.xml

    PATRÓN CORRECTO para poster que emerge del hero y hace scroll con el contenido:

    1. CollapsingToolbarLayout con el backdrop (hero)
    2. NestedScrollView con:
         android:clipToPadding="false"  → permite que el primer hijo se dibuje
                                          ENCIMA del AppBarLayout visualmente
    3. El primer hijo del LinearLayout es un ConstraintLayout con
       android:layout_marginTop="-80dp" → sube el poster sobre el hero
       El CoordinatorLayout permite este overlap porque clipToPadding=false
       hace que el contenido se dibuje fuera de sus propios límites de padding.


-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!--
         HERO — AppBar + CollapsingToolbar
    -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="#1A1A2E"
            app:expandedTitleTextColor="@android:color/transparent"
            app:collapsedTitleTextColor="#FFFFFF"
            app:collapsedTitleTextAppearance="@style/TextAppearance.Material3.TitleMedium">

            <!-- Backdrop en parallax -->
            <ImageView
                android:id="@+id/ivBackdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Backdrop"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.5"
                tools:src="@drawable/ic_movie_placeholder"/>

            <!-- Gradiente: oscuro arriba, funde al fondo abajo -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_hero_overlay"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.5"/>

            <!-- Toolbar fija al colapsar — botón ← automático del NavController -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@android:color/transparent"
                app:navigationIconTint="#FFFFFF"
                app:layout_collapseMode="pin"/>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!--
         CONTENIDO DESPLAZABLE

         android:clipToPadding="false"
           → Permite que el contenido se dibuje fuera del área de padding.
             Sin esto, el marginTop negativo del primer hijo quedaría recortado
             y no se vería el poster sobre el hero.

         app:layout_behavior="@string/appbar_scrolling_view_behavior"
           → Sincroniza el scroll de este NestedScrollView con el AppBarLayout.
             Cuando el usuario sube, el AppBar se colapsa. Cuando baja, se expande.
    -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <!--
                 SECCIÓN HERO-CONTENT: poster + info primaria
                 android:layout_marginTop="-80dp"
                   → Sube este bloque 80dp dentro del área del hero.
                     Como clipToPadding=false, se dibuja sobre el gradiente.
                     Al hacer scroll, este bloque sube junto con todoo el contenido
                     de forma natural → comportamiento correcto.

                 android:background="#1A1A2E"
                   → El fondo del ConstraintLayout cubre el gradiente debajo
                     del poster, dando la ilusión de que el contenido "empuja"
                     hacia arriba al hacer scroll.
             -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-80dp"
                android:background="#1A1A2E"
                android:paddingTop="80dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <!--
                    POSTER — dentro del scroll, sube 80dp sobre el hero.
                    android:layout_marginTop="-80dp" en el ConstraintLayout padre
                    hace que visualmente el poster quede sobre el gradiente.
                    app:cardElevation="16dp" → el poster aparece ENCIMA del gradiente.
                -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPoster"
                    android:layout_width="110dp"
                    android:layout_height="165dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="16dp"
                    app:cardBackgroundColor="#2C2C3E"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivPosterDetail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="Poster de la película"
                        tools:src="@drawable/ic_movie_placeholder"/>

                </androidx.cardview.widget.CardView>

                <!-- INFO PRIMARIA al lado del poster -->
                <LinearLayout
                    android:id="@+id/infoContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical"
                    app:layout_constraintStart_toEndOf="@id/cardPoster"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/cardPoster"
                    app:layout_constraintBottom_toBottomOf="@id/cardPoster">

                    <TextView
                        android:id="@+id/tvRatingDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFC107"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="⭐ 8.7/10"/>

                    <TextView
                        android:id="@+id/tvVotesDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        tools:text="25,489 votos"/>

                    <TextView
                        android:id="@+id/tvReleaseDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"
                        tools:text="1999"/>

                    <TextView
                        android:id="@+id/tvRuntimeDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"
                        tools:text="2h 16min"/>

                    <TextView
                        android:id="@+id/tvPopularityDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"
                        tools:text="🔥 850.2"/>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ── TÍTULO ── -->
            <TextView
                android:id="@+id/tvTitleDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingHorizontal="16dp"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp"
                tools:text="The Matrix"/>

            <!-- ── TAGLINE ── -->
            <TextView
                android:id="@+id/tvTaglineDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingHorizontal="16dp"
                android:textColor="#E91E63"
                android:textSize="13sp"
                android:textStyle="italic"
                android:visibility="gone"
                tools:text="\Welcome to the Real World.\"
                tools:visibility="visible"/>

            <!-- ── CHIPS DE GÉNEROS ── -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupGenres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="16dp"
                app:singleLine="false"
                app:chipSpacingHorizontal="8dp"/>

            <!-- ── DIVIDER ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="#2C2C3E"/>

            <!-- ── DATOS FINANCIEROS ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="16dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Card Presupuesto -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#1E1E2E">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💰 Presupuesto"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp"/>
                        <TextView
                            android:id="@+id/tvBudgetDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="$63.0M"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card Ingresos -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#1E1E2E">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊 Ingresos"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp"/>
                        <TextView
                            android:id="@+id/tvRevenueDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#4CAF50"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="$467.2M"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── SINOPSIS ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="16dp"
                android:text="Sinopsis"
                android:textColor="#E91E63"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:background="#E91E63"/>

            <TextView
                android:id="@+id/tvOverviewDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="16dp"
                android:textColor="#CCCCCC"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                tools:text="Overview text here"/>

            <!-- Espacio para que el FAB no tape el último texto -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!--
         PROGRESS BAR
     -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        app:indicatorColor="#E91E63"
        app:indicatorSize="52dp"
        app:trackColor="#2C2C3E"/>

    <!--
         FAB EXTENDIDO — fijo en la parte inferior
    -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnWatchVideos"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:text="🎬  Ver Videos y Trailers"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="#E91E63"
        app:elevation="8dp"
        app:rippleColor="#C2185B"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>